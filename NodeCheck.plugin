#!name=高级节点检测面板
#!desc=Netflix/OpenAI/TikTok/UDP/IP信息检测
#!author=ChatGPT

[Panel]

节点信息 = script-name=ipinfo, update-interval=300

延迟测试 = script-name=ping, update-interval=300

UDP测试 = script-name=udp, update-interval=300

OpenAI = script-name=openai, update-interval=300

TikTok = script-name=tiktok, update-interval=300

Netflix = script-name=netflix, update-interval=300

[Script]

ipinfo = type=generic, timeout=20, script-path=https://raw.githubusercontent.com/你的用户名/Loon/main/script/ipinfo.js

ping = type=generic, timeout=20, script-path=https://raw.githubusercontent.com/你的用户名/Loon/main/script/ping.js

udp = type=generic, timeout=20, script-path=https://raw.githubusercontent.com/你的用户名/Loon/main/script/udp.js

openai = type=generic, timeout=20, script-path=https://raw.githubusercontent.com/你的用户名/Loon/main/script/openai.js

tiktok = type=generic, timeout=20, script-path=https://raw.githubusercontent.com/你的用户名/Loon/main/script/tiktok.js

netflix = type=generic, timeout=20, script-path=https://raw.githubusercontent.com/你的用户名/Loon/main/script/netflix.js
