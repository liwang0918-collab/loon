#!name=高级节点检测
#!desc=节点解锁/IP信息/UDP/纯净度检测
#!author=ChatGPT
#!icon=https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Speedtest.png

[Script]

节点信息

Node-IP = type=http-request, pattern=^https://nodecheck.loon/ip$, script-path=https://raw.githubusercontent.com/你的用户名/Loon/main/script/ipinfo.js, requires-body=false, timeout=20, enable=true

流媒体解锁

Node-Unlock = type=http-request, pattern=^https://nodecheck.loon/unlock$, script-path=https://raw.githubusercontent.com/你的用户名/Loon/main/script/unlock.js, requires-body=false, timeout=30, enable=true

UDP检测

Node-UDP = type=http-request, pattern=^https://nodecheck.loon/udp$, script-path=https://raw.githubusercontent.com/你的用户名/Loon/main/script/udp.js, requires-body=false, timeout=20, enable=true

IP纯净度

Node-CleanIP = type=http-request, pattern=^https://nodecheck.loon/clean$, script-path=https://raw.githubusercontent.com/你的用户名/Loon/main/script/cleanip.js, requires-body=false, timeout=30, enable=true

节点测速

Node-Ping = type=http-request, pattern=^https://nodecheck.loon/ping$, script-path=https://raw.githubusercontent.com/你的用户名/Loon/main/script/ping.js, requires-body=false, timeout=20, enable=true

[MITM]
hostname = nodecheck.loon
